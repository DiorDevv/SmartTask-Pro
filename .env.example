# PostgreSQL ulanish
DATABASE_URL="postgresql://reja:${DB_PASSWORD:-reja123}@postgres:5432/reja"

# NextAuth sozlamalari
# NEXTAUTH_SECRET yaratish: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-at-least-32-chars-long"
# Server uchun: http://your-domain.com
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Google OAuth (ixtiyoriy)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (ixtiyoriy)
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Docker uchun
DB_PASSWORD="reja123"
PORT=3000

# Rate limiting (ixtiyoriy, lekin Vercel/serverless muhitida tavsiya etiladi)
# https://console.upstash.com dan Redis database yaratib REST URL/TOKEN ni oling.
# Sozlanmasa, in-memory rate limiter ishlatiladi (bitta instansiya doirasida ishlaydi).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Cron uchun tizim endpoint'larini himoyalash (masalan: openssl rand -hex 32)
CRON_SECRET=""
